    <div class="container">
        <div class="row">
            <div class="col-6 mx-auto">
                <h2 class="mb-3">プロフィールを編集</h2>
                <%= form_with model: @user, url: public_user_path(@user), method: :patch do |f| %>
                    <div>   
                        <%= f.label :name, "プロフィール名", class: "form-label" %>
                        <%= f.text_field :name, class:"form-control mb-3" %>
                    </div>
                    <div>
                        <%= f.label :profile_image, "プロフィール画像", class: "form-label" %>
                        <%= f.file_field :profile_image, accept: "image/*", class: "form-control-file mb-3" %>
                    </div>
                    <div>   
                        <%= f.label :profile_statement, "プロフィール文", class: "form-label" %>
                        <%= f.text_area :profile_statement, class:"form-control mb-3" %>
                    </div>
                    <div>
                        <%= link_to "back", public_user_path(@user), class: "btn btn-outline-dark"  %>
                        <%= f.submit "update", class: "btn btn-outline-dark" %>
                    </div>
                <% end %>
            </div>
        </div>
    </div>        