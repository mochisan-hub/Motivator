<div class="container">
    <div class="row">
        <div class="col-6 mx-auto">        
            
            <%=form_with model:@post, url: public_posts_path do |f|%>

            <div class="mb-4">
                <%= f.label :image, "トレーニング画像", class: "form-label" %>
                <%= f.file_field :image, accept: "image/*", class: "form-control-file mb-3" %>
            </div>

            <h6>本文</h6>
                <%= f.text_area :content %>

            <hr><h6>トレーニング内容</h6>

            <%= f.fields_for :traning_details do |df| %>
                <div class="training-field mb-3">

                <%= df.label :body_part, "部位", class: "form-label" %>
                    <%= df.text_field :body_part, class: "form-control" %>

                <%= df.label :menu, "種目名", class: "form-label" %>
                    <%= f.text_field :menu, class: "form-control" %>

                <%= df.label :reps, "回数", class: "form-label" %>
                    <%= f.text_field :reps, class: "form-control" %>

                <%= df.label :reps, "重量", class: "form-label" %>
                    <%= f.text_field :weight, class: "form-control" %>

                <%= df.label :reps, "距離", class: "form-label" %>
                    <%= f.text_field :distance, class: "form-control" %>

                <%= df.label :reps, "時間", class: "form-label" %>
                    <%= f.text_field :time, class: "form-control" %>
            <% end %>

            <%= f.submit '投稿', class: "mt-3" %>

            <% end %>
        </div>
    </div>
</div>
