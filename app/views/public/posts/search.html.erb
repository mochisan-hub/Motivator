<%= form_with url: public_posts_path, method: :get, local: true do |f| %>
  <%= f.text_field :keyword, value: params[:keyword], placeholder: "キーワードを入力" %>
  <%= f.submit "検索" %>
<% end %>

<div class="container-fluid px-1 py-3">
    <div class="row g-1">
        <% @posts.each do |post| %>
            <div class="col-4">
                <div class="raito ratio-1x1 overflow-hidden">
                    <%= link_to public_post_path(post) do %>
                        <% if post.image.attached? %>
                            <%= image_tag post.image, class: "object-fit-cover w-100 h-100" %>
                        <% else %>
                            <%= image_tag 'no_image.jpg', class: "object-fit-cover w-100 h-100" %>
                        <% end %>
                    <% end %>
                </div>
            </div>
        <% end %>
    </div>
</div>

