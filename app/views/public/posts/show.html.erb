<div class = "container">
    <div class = "row">
        <div class = "col-7">
            <%= image_tag @post.get_image %>
        </div>

        <div class = "col-5">
            <div class = "row">
                <div class = "col-3 text-center">
                    <div class="rounded-circle bg-secondary" style="width: 40px; height: 40px;"></div>
                </div>
                <div class="col-7 text-center">
                    <strong><%= @post.user.name %></strong>
                </div>
                <div class="col-3">
                    <% if @post.user == current_user %>
                        <%= link_to "削除", public_post_path(@post), method: :delete %>
                    <% end %>
                </div>
            </div>
            <div class = "row">
                <div class = "col-12">
                    <%= @post.content %>
                </div>
            </div>    
            <p>投稿日：<%= @post.created_at.strftime('%Y/%m/%d') %></p>
        </div>
    </div>
</div>

